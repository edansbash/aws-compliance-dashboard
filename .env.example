# =============================================================================
# Local Development Configuration
# =============================================================================
# Copy this to .env for local development

# Your AWS SSO profile name (from ~/.aws/config)
# Run: aws sso login --profile compliance-scanner before starting
AWS_PROFILE=compliance-scanner

# Default region for AWS API calls
AWS_DEFAULT_REGION=us-east-2

# Database (local defaults for docker-compose)
DATABASE_URL=postgresql://postgres:postgres@db:5432/compliance

# =============================================================================
# Multi-Account Setup for Local Development
# =============================================================================
# For scanning multiple AWS accounts locally:
#
# 1. Ensure your SSO user has permission to assume ReadOnlyAccess role
#    in each target account (typically via AWS Organizations)
#
# 2. Add accounts via the UI with these settings:
#    - Account Name: Descriptive name (e.g., "Production", "Staging")
#    - Account ID: 12-digit AWS account ID
#    - Role ARN: arn:aws:iam::<ACCOUNT_ID>:role/ReadOnlyAccess
#    - External ID: Leave empty (not needed for org accounts)
#
# 3. The scanner will use your SSO credentials to assume the role
#    in each account
#
# Example accounts to add via UI:
# - Production:  123456789012, arn:aws:iam::123456789012:role/ReadOnlyAccess
# - Staging:     234567890123, arn:aws:iam::234567890123:role/ReadOnlyAccess
# - Development: 345678901234, arn:aws:iam::345678901234:role/ReadOnlyAccess

# =============================================================================
# JIRA Integration (optional)
# =============================================================================
# Configure these to enable JIRA ticket creation from findings

JIRA_BASE_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ
JIRA_ISSUE_TYPE=Bug
JIRA_ASSIGNEE_EMAIL=assignee@company.com

# =============================================================================
# Slack Integration (optional)
# =============================================================================
# Configure these to enable Slack notifications

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# Channel name for display purposes only (actual channel is configured in Slack when creating the webhook)
SLACK_CHANNEL_NAME=your-channel-name

# =============================================================================
# IaC (Infrastructure as Code) Scanning - GitHub Integration (optional)
# =============================================================================
# Pull Trivy/tfsec scan results from GitHub Code Scanning API

# GitHub Personal Access Token with security_events:read permission
GITHUB_TOKEN=github_pat_xxxxx

# GitHub repository to sync
IAC_GITHUB_OWNER=your-org
IAC_GITHUB_REPO=your-iac-repo
IAC_GITHUB_BRANCH=main

# =============================================================================
# Frontend Display Settings (optional)
# =============================================================================
# Timezone for displaying dates/times in the frontend
# If not set, uses browser's local timezone
# Examples: "America/New_York", "America/Los_Angeles", "UTC", "Europe/London"
VITE_DISPLAY_TIMEZONE=
